---
import CmsLayout from "@/layouts/CmsLayout.astro";
---

<CmsLayout title="Tags CMS">
  <section class="space-y-6">
    <header class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-xs uppercase tracking-widest text-cyan-400">CMS Taxonomy</p>
        <h1 class="text-3xl font-bold mt-1">Tags</h1>
        <p class="text-slate-400 mt-2">Gestiona etiquetas para clasificacion secundaria del blog.</p>
      </div>
      <a href="/cms" class="rounded-lg border border-slate-700 px-4 py-2 text-sm hover:bg-slate-800">Dashboard</a>
    </header>

    <nav class="flex flex-wrap gap-2 text-sm">
      <a href="/cms/blog" class="rounded-md border border-slate-700 px-3 py-1.5 hover:bg-slate-800">Blog</a>
      <a href="/cms/categories" class="rounded-md border border-slate-700 px-3 py-1.5 hover:bg-slate-800">Categorias</a>
      <a href="/cms/tags" class="rounded-md border border-cyan-500/70 bg-cyan-500/10 px-3 py-1.5 text-cyan-300">Tags</a>
      <a href="/cms/authors" class="rounded-md border border-slate-700 px-3 py-1.5 hover:bg-slate-800">Autores</a>
    </nav>

    <section class="rounded-xl border border-slate-800 bg-slate-900/70 p-4 space-y-4">
      <div class="grid gap-3 lg:grid-cols-3">
        <label class="block text-sm">
          <span class="text-slate-300">Nombre *</span>
          <input id="cms-tags-name" type="text" class="mt-1 w-full rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-slate-100" />
        </label>
        <label class="block text-sm">
          <span class="text-slate-300">Slug *</span>
          <input id="cms-tags-slug" type="text" placeholder="seo-tecnico" class="mt-1 w-full rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-slate-100" />
        </label>
        <label class="block text-sm lg:col-span-1">
          <span class="text-slate-300">Descripcion</span>
          <textarea id="cms-tags-description" rows="2" class="mt-1 w-full rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-slate-100"></textarea>
        </label>
      </div>

      <div class="flex flex-wrap gap-2">
        <button id="cms-tags-submit" type="button" class="rounded-lg bg-cyan-500 px-4 py-2 text-sm font-semibold text-slate-950 hover:bg-cyan-400">
          Crear tag
        </button>
        <button id="cms-tags-refresh" type="button" class="rounded-lg border border-slate-700 px-4 py-2 text-sm hover:bg-slate-800">
          Refrescar
        </button>
      </div>

      <p id="cms-tags-message" class="text-sm text-slate-300"></p>
      <p id="cms-tags-error" class="text-sm text-rose-400"></p>

      <div class="overflow-x-auto rounded-lg border border-slate-800">
        <table class="w-full min-w-[720px] text-sm">
          <thead class="bg-slate-900/90 text-slate-300">
            <tr>
              <th class="px-4 py-2 text-left font-medium">Nombre</th>
              <th class="px-4 py-2 text-left font-medium">Slug</th>
              <th class="px-4 py-2 text-left font-medium">Estado</th>
              <th class="px-4 py-2 text-left font-medium">Actualizado</th>
              <th class="px-4 py-2 text-right font-medium">Accion</th>
            </tr>
          </thead>
          <tbody id="cms-tags-table-rows" class="bg-slate-950/80"></tbody>
        </table>
      </div>
    </section>
  </section>

  <script>
    import { initTagsPage } from "@/features/cms/taxonomy/ui/taxonomy-page";

    await initTagsPage();
  </script>
</CmsLayout>
