---
import { Picture } from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import Sectionhead from "@/components/sectionhead.astro";
import MvpPlanningBanner from "@/components/mvp-planning-banner.astro";
import { listPublishedBlogPosts } from "@/features/public-blog/data/public-blog-repository";

function formatDateSpanish(date: Date): string {
  const months = [
    "enero",
    "febrero",
    "marzo",
    "abril",
    "mayo",
    "junio",
    "julio",
    "agosto",
    "septiembre",
    "octubre",
    "noviembre",
    "diciembre",
  ];
  const day = date.getDate();
  const month = months[date.getMonth()];
  const year = date.getFullYear();
  return `${day} de ${month}, ${year}`;
}

const publishedBlogEntries = await listPublishedBlogPosts();
---

<Layout title="Blog">
  <Container>
    <Sectionhead>
      <Fragment slot="title">Blog</Fragment>
      <Fragment slot="desc">
        Aprende sobre automatizacion, No-Code e IA para hacer crecer tu negocio. Casos reales, ejemplos practicos y estrategias que funcionan.
      </Fragment>
    </Sectionhead>
    <main class="mt-16">
      <ul class="grid gap-16 max-w-4xl mx-auto">
        {
          publishedBlogEntries.map((blogPostEntry, index) => (
            <li>
              <a href={`/blog/${blogPostEntry.categorySlug}/${blogPostEntry.slug}`}>
                <div class="grid md:grid-cols-2 gap-5 md:gap-10 items-center">
                  {
                    blogPostEntry.imageSrc.startsWith("http") ? (
                      <img
                        src={blogPostEntry.imageSrc}
                        alt={blogPostEntry.imageAlt}
                        loading={index <= 2 ? "eager" : "lazy"}
                        decoding={index <= 2 ? "sync" : "async"}
                        class="w-full rounded-md object-cover object-center bg-white aspect-[4/3]"
                      />
                    ) : (
                      <Picture
                        src={blogPostEntry.imageSrc}
                        alt={blogPostEntry.imageAlt}
                        sizes="(max-width: 800px) 100vw, 800px"
                        width={800}
                        height={600}
                        loading={index <= 2 ? "eager" : "lazy"}
                        decoding={index <= 2 ? "sync" : "async"}
                        class="w-full rounded-md object-cover object-center bg-white"
                      />
                    )
                  }
                  <div>
                    <span class="text-blue-400 uppercase tracking-wider text-sm font-medium">
                      {blogPostEntry.categoryName}
                    </span>

                    <h2 class="text-3xl font-semibold leading-snug tracking-tight mt-1 ">
                      {blogPostEntry.title}
                    </h2>

                    <div class="flex gap-2 mt-3">
                      <span class="text-gray-400">
                        {blogPostEntry.authorName}
                      </span>
                      <span class="text-gray-400">• </span>
                      <time
                        class="text-gray-400"
                        datetime={blogPostEntry.publishDate.toISOString()}>
                        {formatDateSpanish(blogPostEntry.publishDate)}
                      </time>
                    </div>
                  </div>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </main>
    <MvpPlanningBanner />
  </Container>
</Layout>
