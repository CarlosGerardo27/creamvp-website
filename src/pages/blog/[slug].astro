---
import { resolveLegacyBlogSlug } from "@/features/public-blog/data/public-blog-repository";

export const prerender = false;

const slug = Astro.params.slug?.trim() ?? "";

if (!slug) {
  Astro.response.status = 404;
} else {
  const resolvedPost = await resolveLegacyBlogSlug(slug);
  if (!resolvedPost) {
    Astro.response.status = 404;
  } else {
    return Astro.redirect(`/blog/${resolvedPost.categorySlug}/${resolvedPost.slug}`, 301);
  }
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Entrada no encontrada</title>
    <meta name="robots" content="noindex,nofollow" />
  </head>
  <body>
    <main style="font-family: Inter, sans-serif; max-width: 720px; margin: 4rem auto; padding: 0 1rem;">
      <h1>Entrada no encontrada</h1>
      <p>La entrada solicitada no existe o fue movida.</p>
      <p><a href="/blog">Volver al blog</a></p>
    </main>
  </body>
</html>
