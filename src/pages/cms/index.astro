---
import CmsLayout from "@/layouts/CmsLayout.astro";
---

<CmsLayout title="Dashboard CMS">
  <section class="space-y-8">
    <header class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-xs uppercase tracking-widest text-cyan-400">Panel Editorial</p>
        <h1 class="text-3xl font-bold mt-1">CMS CreaMVP</h1>
        <p class="text-slate-400 mt-2">Panel operativo para blog, categorias, tags y autores.</p>
      </div>
      <div class="flex gap-2">
        <a href="/cms/blog" class="rounded-lg bg-cyan-500 px-4 py-2 text-sm font-semibold text-slate-950 hover:bg-cyan-400">
          Ir a Blog
        </a>
        <button
          id="cms-logout"
          class="rounded-lg border border-slate-700 px-4 py-2 text-sm hover:bg-slate-800 transition"
        >
          Cerrar sesion
        </button>
      </div>
    </header>

    <div class="grid gap-4 md:grid-cols-3">
      <article class="rounded-xl border border-slate-800 bg-slate-900/70 p-4">
        <h2 class="font-semibold">Usuario</h2>
        <p id="cms-user-email" class="text-slate-300 mt-2 text-sm">Cargando...</p>
      </article>
      <article class="rounded-xl border border-slate-800 bg-slate-900/70 p-4">
        <h2 class="font-semibold">Rol</h2>
        <p id="cms-user-role" class="text-slate-300 mt-2 text-sm">Cargando...</p>
      </article>
      <article class="rounded-xl border border-slate-800 bg-slate-900/70 p-4">
        <h2 class="font-semibold">Estado</h2>
        <p id="cms-user-status" class="text-slate-300 mt-2 text-sm">Validando acceso...</p>
      </article>
    </div>

    <div class="rounded-xl border border-slate-800 bg-slate-900/70 p-4">
      <h2 class="font-semibold">Modulos CMS disponibles</h2>
      <div class="mt-3 flex flex-wrap gap-2 text-sm">
        <a href="/cms/blog" class="rounded-md border border-cyan-500/70 bg-cyan-500/10 px-3 py-1.5 text-cyan-300">Blog</a>
        <a href="/cms/blog/new" class="rounded-md border border-slate-700 px-3 py-1.5 hover:bg-slate-800">Nuevo post</a>
        <a href="/cms/categories" class="rounded-md border border-slate-700 px-3 py-1.5 hover:bg-slate-800">Categorias</a>
        <a href="/cms/tags" class="rounded-md border border-slate-700 px-3 py-1.5 hover:bg-slate-800">Tags</a>
        <a href="/cms/authors" class="rounded-md border border-slate-700 px-3 py-1.5 hover:bg-slate-800">Autores</a>
      </div>
    </div>
  </section>

  <script>
    import { getCurrentCmsSession, fetchCurrentCmsProfile, signOutCmsSession } from "@/features/cms/auth/session";

    const emailEl = document.getElementById("cms-user-email");
    const roleEl = document.getElementById("cms-user-role");
    const statusEl = document.getElementById("cms-user-status");
    const logoutButton = document.getElementById("cms-logout");

    const session = await getCurrentCmsSession();
    const profile = await fetchCurrentCmsProfile();

    if (emailEl) {
      emailEl.textContent = session?.user?.email ?? "Sin sesion";
    }
    if (roleEl) {
      roleEl.textContent = profile?.role ?? "Sin rol";
    }
    if (statusEl) {
      statusEl.textContent = profile?.is_active
        ? "Acceso editorial activo"
        : "Usuario sin acceso editorial";
    }

    logoutButton?.addEventListener("click", async () => {
      await signOutCmsSession();
      window.location.href = "/cms/login";
    });
  </script>
</CmsLayout>
