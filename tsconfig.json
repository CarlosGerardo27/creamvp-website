{
  "extends": "astro/tsconfigs/base",
  "compilerOptions": {
    "baseUrl": ".",
    "strictNullChecks": true,
    "types": ["astro/client"],
    "paths": {
      "@/*": ["src/*"],
      "~/*": ["./*"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    ".vercel",
    "coverage",
    "test-results"
  ]
}
