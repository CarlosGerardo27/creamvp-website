---
import CmsLayout from "@/layouts/CmsLayout.astro";
---

<CmsLayout title="Sin Permisos" requireAuth={false}>
  <section class="max-w-xl mx-auto mt-12 text-center">
    <p class="text-xs uppercase tracking-widest text-amber-400">Acceso restringido</p>
    <h1 class="text-3xl font-bold mt-2">No tienes permisos para esta sección</h1>
    <p class="text-slate-300 mt-4">
      Tu usuario no cuenta con rol editorial activo para acceder al CMS.
    </p>

    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="/cms/login" class="rounded-lg bg-cyan-500 px-4 py-2 font-semibold text-slate-950 hover:bg-cyan-400 transition">
        Volver a Login
      </a>
      <a href="/" class="rounded-lg border border-slate-700 px-4 py-2 hover:bg-slate-800 transition">
        Ir al sitio
      </a>
    </div>
  </section>
</CmsLayout>

