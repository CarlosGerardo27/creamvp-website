---
import { marked } from "marked";
import { Picture } from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import ReadingProgress from "@/components/ReadingProgress.astro";
import BlogFAQs from "@/components/BlogFAQs.astro";
import BlogShare from "@/components/BlogShare.astro";
import MvpPlanningBanner from "@/components/mvp-planning-banner.astro";
import { listPublishedBlogPosts } from "@/features/public-blog/data/public-blog-repository";
import type { PublicBlogPost } from "@/features/public-blog/domain/types";

type BlogDetailProps = {
  post: PublicBlogPost;
};

export async function getStaticPaths() {
  const posts = await listPublishedBlogPosts();
  return posts.map((post) => ({
    params: {
      categoria: post.categorySlug,
      slug: post.slug,
    },
    props: {
      post,
    } satisfies BlogDetailProps,
  }));
}

function formatDateSpanish(date: Date): string {
  const months = [
    "enero",
    "febrero",
    "marzo",
    "abril",
    "mayo",
    "junio",
    "julio",
    "agosto",
    "septiembre",
    "octubre",
    "noviembre",
    "diciembre",
  ];
  const day = date.getDate();
  const month = months[date.getMonth()];
  const year = date.getFullYear();
  return `${day} de ${month}, ${year}`;
}

function buildInitials(name: string): string {
  const initials = name
    .split(" ")
    .map((segment) => segment.trim())
    .filter(Boolean)
    .slice(0, 2)
    .map((segment) => segment[0]?.toUpperCase() ?? "")
    .join("");

  return initials || "CM";
}

const { post } = Astro.props as BlogDetailProps;
const markdownHtml = post.contentMarkdown
  ? (marked.parse(post.contentMarkdown) as string)
  : "<p>Sin contenido.</p>";
const articleImage = post.imageSrc.startsWith("http")
  ? post.imageSrc
  : new URL(post.imageSrc, Astro.site).toString();
const articleUrl = new URL(Astro.url.pathname, Astro.site).toString();
const authorInitials = buildInitials(post.author.name);
const authorSocialLinks = [
  { key: "personal", label: "Sitio web", href: post.author.socialLinks.personalUrl },
  { key: "linkedin", label: "LinkedIn", href: post.author.socialLinks.linkedinUrl },
  { key: "x", label: "X", href: post.author.socialLinks.xUrl },
  { key: "instagram", label: "Instagram", href: post.author.socialLinks.instagramUrl },
  { key: "facebook", label: "Facebook", href: post.author.socialLinks.facebookUrl },
  { key: "tiktok", label: "TikTok", href: post.author.socialLinks.tiktokUrl },
].filter((item) => Boolean(item.href));

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Inicio",
      item: new URL("/", Astro.site).toString(),
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Blog",
      item: new URL("/blog", Astro.site).toString(),
    },
    {
      "@type": "ListItem",
      position: 3,
      name: post.categoryName,
      item: new URL(`/blog/${post.categorySlug}`, Astro.site).toString(),
    },
    {
      "@type": "ListItem",
      position: 4,
      name: post.title,
      item: articleUrl,
    },
  ],
};
---

<Layout
  title={post.title}
  description={post.snippet}
  image={articleImage}
  type="article"
  author={post.authorName}
  publishDate={post.publishDate}
  siteName="CreaMVP"
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <ReadingProgress />
  <Container>
    <article itemscope itemtype="https://schema.org/BlogPosting">
      <div class="mx-auto max-w-3xl mt-14">
        <span class="text-blue-400 uppercase tracking-wider text-sm font-medium">
          {post.categoryName}
        </span>
        <h1
          itemprop="headline"
          class="text-4xl lg:text-5xl font-bold lg:tracking-tight mt-1 lg:leading-tight">
          {post.title}
        </h1>

        <p itemprop="description" class="text-lg text-slate-600 mt-4 leading-relaxed">
          {post.snippet}
        </p>

        <div class="flex gap-2 mt-4 items-center flex-wrap md:flex-nowrap">
          <span itemprop="author" itemscope itemtype="https://schema.org/Person" class="text-gray-400">
            <span itemprop="name">{post.authorName}</span>
          </span>
          <span class="text-gray-400">•</span>
          <time
            itemprop="datePublished"
            class="text-gray-400"
            datetime={post.publishDate.toISOString()}>
            {formatDateSpanish(post.publishDate)}
          </time>
          <span class="text-gray-400 hidden md:block">•</span>
          <div class="w-full md:w-auto flex flex-wrap gap-3">
            {
              post.tags.map((tag) => (
                <span class="text-sm text-gray-500">#{tag.name}</span>
              ))
            }
          </div>
        </div>
      </div>

      <div itemprop="image" itemscope itemtype="https://schema.org/ImageObject" class="mx-auto max-w-3xl mt-8">
        {
          post.imageSrc.startsWith("http") ? (
            <img
              itemprop="url"
              src={post.imageSrc}
              alt={post.imageAlt}
              class="w-full rounded-lg"
            />
          ) : (
            <Picture
              src={post.imageSrc}
              alt={post.imageAlt}
              class="w-full rounded-lg"
              width={1200}
              height={600}
              sizes="(max-width: 800px) 100vw, 1200px"
            />
          )
        }
        <meta itemprop="caption" content={post.imageAlt} />
      </div>

      <div itemprop="articleBody" class="mx-auto prose prose-lg mt-8 max-w-3xl" set:html={markdownHtml} />

      <section data-testid="blog-author-card" class="mx-auto mt-10 max-w-3xl rounded-2xl border border-gray-200 bg-white p-6">
        <h2 class="text-xl font-semibold text-gray-900">Sobre el autor</h2>
        <div class="mt-4 flex flex-col gap-4 sm:flex-row">
          <div class="h-16 w-16 shrink-0 overflow-hidden rounded-full border border-gray-200 bg-gray-100">
            {
              post.author.photoUrl ? (
                <img
                  src={post.author.photoUrl}
                  alt={`Foto de ${post.author.name}`}
                  class="h-full w-full object-cover"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="flex h-full w-full items-center justify-center text-sm font-semibold text-gray-600">
                  {authorInitials}
                </div>
              )
            }
          </div>
          <div class="min-w-0 flex-1">
            <p class="text-base font-semibold text-gray-900">{post.author.name}</p>
            <p class="mt-1 text-sm leading-relaxed text-gray-600">
              {post.author.bio ?? "Equipo editorial de CreaMVP."}
            </p>
            {
              authorSocialLinks.length ? (
                <div class="mt-3 flex flex-wrap gap-2">
                  {authorSocialLinks.map((link) => (
                    <a
                      href={link.href as string}
                      target="_blank"
                      rel="noopener noreferrer nofollow"
                      class="inline-flex rounded-full border border-gray-200 px-3 py-1 text-xs font-medium text-gray-700 hover:border-blue-300 hover:text-blue-600"
                    >
                      {link.label}
                    </a>
                  ))}
                </div>
              ) : null
            }
          </div>
        </div>
      </section>

      <BlogFAQs faqs={post.faqs.map((faq) => ({ question: faq.question, answer: faq.answer }))} />
      <BlogShare title={post.title} url={articleUrl} />
    </article>

    <div class="text-center mt-8">
      <a
        href="/blog"
        class="bg-gray-100 px-5 py-3 rounded-xl hover:bg-gray-200 transition"
      >
        ← Volver al Blog
      </a>
    </div>
    <MvpPlanningBanner />
  </Container>
</Layout>
